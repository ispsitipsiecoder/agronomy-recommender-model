# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub

# IMD API (apply at mausam.imd.gov.in/responsive/apis.php)
IMD_API_KEY=your_imd_api_key_here

# Oracle Cloud Infrastructure (Phase 4)
OCI_DB_NAME=agronomy_db
OCI_DB_USER=your_db_user
OCI_DB_PASSWORD=your_db_password
OCI_DB_HOST=your_oci_host.oraclecloud.com

# Optional: Sentinel Hub for NDVI (Phase 2)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
